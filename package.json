{
    "name": "@posthog/openclaw",
    "version": "0.2.2",
    "description": "PostHog LLM Analytics plugin for OpenClaw",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/PostHog/posthog-openclaw.git"
    },
    "author": "PostHog",
    "keywords": [
        "posthog",
        "openclaw",
        "ai",
        "llm",
        "observability",
        "tracing",
        "analytics"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "files": [
        "dist",
        "index.ts",
        "src/**/*.ts",
        "!src/**/*.test.ts",
        "openclaw.plugin.json"
    ],
    "scripts": {
        "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
        "build": "pnpm clean && tsc -p tsconfig.build.json",
        "test": "vitest run",
        "test:unit": "vitest run",
        "test:watch": "vitest",
        "format": "oxfmt --check .",
        "format:fix": "oxfmt --write .",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "pack:verify": "pnpm build && node scripts/verify-package.mjs",
        "prepack": "pnpm build",
        "typecheck": "tsc --noEmit",
        "changeset": "changeset",
        "version": "changeset version",
        "prepublishOnly": "pnpm format && pnpm lint && pnpm test:unit && pnpm typecheck && pnpm pack:verify"
    },
    "dependencies": {
        "posthog-node": "^5.0.0"
    },
    "peerDependencies": {
        "openclaw": ">=2026.2.0"
    },
    "peerDependenciesMeta": {
        "openclaw": {
            "optional": true
        }
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.8",
        "@types/node": "^25.3.2",
        "oxfmt": "^0.40.0",
        "oxlint": "^1.55.0",
        "typescript": "^5.8.0",
        "vitest": "^3.0.0"
    },
    "openclaw": {
        "extensions": [
            "./index.ts"
        ],
        "runtimeExtensions": [
            "./dist/index.js"
        ]
    },
    "bugs": {
        "url": "https://github.com/PostHog/posthog-openclaw/issues"
    },
    "homepage": "https://github.com/PostHog/posthog-openclaw#readme",
    "packageManager": "pnpm@10.29.3",
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    }
}
